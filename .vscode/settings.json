    //  for ms-vscode.cpptools
    "C_Cpp.errorSquiggles": "disabled",
    "C_Cpp.intelliSenseEngine": "default",
    // "C_Cpp.codeAnalysis.clangTidy.enabled": true,

    "clangd.arguments": [
        "--background-index",
        "--compile-commands-dir=${workspaceFolder}/build",
        "--clang-tidy", // bật clang-tidy
        "--completion-style=detailed", // autocomplete chi tiết hơn
        "--header-insertion=iwyu", // tự thêm #include khi cần
        "--suggest-missing-includes" // gợi ý include còn thiếu],
    ],

    // for ms-vscode.cpptools on Linux
    // "C_Cpp.default.compilerPath": "/usr/bin/clang++",
    // for ms-vscode.cpptools on Windows
    "C_Cpp.default.compilerPath": "C:/Program Files/LLVM/bin/clang++.exe",

    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",

    "C_Cpp.clang_format_path": "C:\\Program Files\\LLVM\\bin\\clang-format.exe",

    //  for ms-vscode.cpptools
    "C_Cpp.default.cppStandard": "c++23",
    "C_Cpp.default.cStandard": "c23",

    "editor.autoClosingBrackets": "always",
    "editor.autoClosingQuotes": "always",

    "[cpp]": {
        "editor.suggest.showKeywords": true,
        "editor.suggest.showPreview": true,
        "editor.suggest.showStatusBar": true,
        "editor.suggest.showStatusBarIcon": true,
        "editor.quickSuggestions": {
            "strings": "on"
        },
        "editor.inlayHints.enabled": "off",
        "editor.suggest.localityBonus": true,
        "editor.acceptSuggestionOnEnter": "on",
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit",
            "source.fixAll": "explicit",
            "source.fixAll.eslint": "explicit",
            "source.organizeImports.eslint": "explicit"
        },
        "editor.tokenColorCustomizations": {
            "comments": {
                "foreground": "#10B981",
                "fontStyle": "italic"
            }
        },
        "search.exclude": {
            "**/.git": true,
            "**/.svn": true,
            "**/.hg": true,
            "**/CVS": true,
            "**/.DS_Store": true,
            "**/.cache": true,
            "**/.npm": true,
            "**/node_modules": true,
            "**/bower_components": true
        }
